#!/usr/bin/env bash

usge() {
    echo "Usage: ${0##*/} [Option] [Argument]"
    echo "  -a      Add extension"
    echo "  -e      Replace extension"
    echo "  -f      Force change extension"
    echo "  -n      Numeric naming (default prefix: 'file')"
    echo "  -u      Change file name (UUID)"
    echo "  -t      Change file name (timestamp)"
    echo "  -r      Change file name (/dev/urandom)"
    echo "  -h      Display this help message"
}
usage() {
    cat << EOF
Usage: ${0##*/} [OPTION] [ARGUMENT]

A minimalist, high-performance batch file renamer.

Options:
    -a <ext>           Add extension to all files
    -e <old> <new>     Replace a specific file extension
    -f <ext>           Force change all extensions to a new type
    -n [prefix]        Sequential numeric naming (Default: 'file_01.ext')
    -u                 Rename files to unique UUIDv4 hashes
    -t                 Rename files using a chronological timestamp
    -r                 Rename files to random alphanumeric strings
    -h                 Display this help message and exit

Examples:
    ${0##*/} -e mp4 mkv      Change all .mp4 files to .mkv
    ${0##*/} -n photo        Rename files to photo_01, photo_02, etc.

EOF
}

(($# < 1)) && { usage; exit 1; }

add_ext() {
    [[ -z "$1" ]] && { echo "Usage: br -a <ext>"; return 1; }

    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        mv "$f" "${f}.${1}"
    done
}

chg_ext() {
    [[ -z "$1" ]] || [[ -z "$2" ]] && \
        { echo "Usage: br -e <old_ext> <new_ext>"; return 1; }
    
    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        if [[ "${f##*.}" == "$1" ]]; then
            mv "$f" "${f%.$1}.$2" 2> /dev/null
        fi
    done
}

chg_all() {
    [[ -z "$1" ]] && { echo "Usage: br -f <ext>"; return 1; }

    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        mv "$f" "${f%.*}.${1}"
    done
}

uuid_name() {
    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        mv "$f" "$(uuidgen).${f##*.}"
    done
}

time_name() {
    local count=1
    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        local datetime=$(date +"%Y%m%d_%H%M%S")
        local pad_count=$(printf "%02d" "$count") 
        mv "$f" "${datetime}_${pad_count}.${f##*.}"
        ((count++))
    done
}

num_name() {
    local count=1
    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        local pad_count=$(printf "%02d" "$count")
        mv "$f" "${1:-file}_${pad_count}.${f##*.}"
        ((count++))
    done
}

rand_name() {
    for f in *; do
        [[ -e "$f" ]] || { echo "No files found!"; return 1; }
        [[ -f "$f" ]] || continue
        local rand=$(tr -cd 'a-z0-9' </dev/urandom | head -c15)
        mv "$f" "${rand}.${f##*.}"
    done
}

case "$1" in
    -a ) add_ext "$2" ;;
    -e ) chg_ext "$2" "$3" ;;
    -f ) chg_all "$2" ;;
    -u ) uuid_name ;;
    -t ) time_name ;;
    -n ) num_name "$2" ;;
    -r ) rand_name ;;
    -h ) usage ;;
    * ) echo "Invalid option: $1"
        echo "Try, ${0##*/} -h to see usage"; exit 1 ;;
esac
